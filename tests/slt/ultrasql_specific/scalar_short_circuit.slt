# UltraSQL-authored SQLLogicTest shard for CASE / COALESCE short-circuit
# (PostgreSQL integer-division semantics).
#
# A non-taken CASE branch or a skipped COALESCE argument must NOT be evaluated,
# so a fallible integer expression (division by zero) hidden in a non-taken
# position returns a value instead of raising -- matching PostgreSQL. The
# selected branch is still evaluated, so a fallible *taken* branch raises.
#
# This is UltraSQL-specific and deliberately NOT in the portable differential
# suite: DuckDB performs floating-point division (`1 / 0` -> inf, and integer
# `99` is widened to `99.0`) and does not raise on integer division by zero, so
# these PostgreSQL integer-division queries are not portable to DuckDB/SQLite.

query I nosort
SELECT CASE WHEN false THEN 1 / 0 ELSE 99 END
----
99

query I nosort
SELECT CASE WHEN false THEN 1 / 0 WHEN true THEN 7 ELSE 1 / 0 END
----
7

query I nosort
SELECT CASE 1 WHEN 2 THEN 1 / 0 WHEN 1 THEN 5 ELSE 1 / 0 END
----
5

query I nosort
SELECT COALESCE(7, 1 / 0)
----
7

# The selected branch is still evaluated, so a fallible *taken* branch raises --
# short-circuiting must not swallow genuine errors (PostgreSQL errors too).
statement error
SELECT CASE WHEN true THEN 1 / 0 ELSE 99 END

# Data-driven COALESCE short-circuit: COALESCE stops at the first non-NULL, so a
# fallible later argument is skipped on rows where an earlier one is non-NULL.
statement ok
CREATE TABLE slt_short_circuit (a INT NOT NULL, c INT NOT NULL)

statement ok
INSERT INTO slt_short_circuit VALUES (10, 0), (20, 4)

# c = 0: the CASE yields 7, so `a / c` is never evaluated (no divide-by-zero).
query I nosort
SELECT COALESCE(CASE WHEN c = 0 THEN 7 ELSE NULL END, a / c) FROM slt_short_circuit WHERE c = 0
----
7

# c <> 0: the CASE is NULL, so COALESCE falls through to `a / c` (= 20 / 4).
query I nosort
SELECT COALESCE(CASE WHEN c = 0 THEN 7 ELSE NULL END, a / c) FROM slt_short_circuit WHERE c = 4
----
5

statement ok
DROP TABLE slt_short_circuit
