# UltraSQL-authored portable SQLLogicTest coverage for benchmark replay.

statement ok
CREATE TABLE slt_bench_numbers (id INT NOT NULL, grp INT NOT NULL, amount INT NOT NULL, label TEXT)

statement ok
INSERT INTO slt_bench_numbers VALUES (1, 1, 10, 'a'), (2, 1, 20, 'b'), (3, 2, 30, 'c'), (4, 2, 40, 'd'), (5, 3, 50, 'e'), (6, 3, 60, 'f'), (7, 1, 70, 'g'), (8, 2, 80, 'h')

query I nosort
SELECT COUNT(*) FROM slt_bench_numbers
----
8

query I nosort
SELECT SUM(amount) FROM slt_bench_numbers WHERE grp = 2
----
150

query II nosort
SELECT id, amount FROM slt_bench_numbers WHERE amount >= 40 ORDER BY amount DESC
