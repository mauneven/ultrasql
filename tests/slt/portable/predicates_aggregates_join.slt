statement ok
CREATE TABLE slt_bench_groups (grp INT NOT NULL, name TEXT)

statement ok
INSERT INTO slt_bench_groups VALUES (1, 'low'), (2, 'mid'), (3, 'high')

query IT rowsort
SELECT slt_bench_numbers.id, slt_bench_groups.name FROM slt_bench_numbers JOIN slt_bench_groups ON slt_bench_numbers.grp = slt_bench_groups.grp WHERE slt_bench_numbers.amount >= 50
----
5
high
