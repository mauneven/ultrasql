# UltraSQL-authored portable SQLLogicTest shard for portable scalar expression coverage.
# Keep this reviewed shard small; third-party expansion belongs in audited imported shards.

statement ok
CREATE TABLE slt_scalar_expr (id INT NOT NULL, a INT NOT NULL, b INT NOT NULL, label TEXT)

statement ok
INSERT INTO slt_scalar_expr VALUES (1, 2, 3, 'alpha'), (2, 5, 5, 'beta'), (3, 9, 4, 'gamma'), (4, 12, 6, NULL)

query II rowsort
SELECT id, a + b FROM slt_scalar_expr
----
1
5
2
10
3
13
4
18

query II rowsort
SELECT id, a * b FROM slt_scalar_expr WHERE b >= 4
----
2
25
3
36
4
72

query I rowsort
SELECT id FROM slt_scalar_expr WHERE (a - b) > 0
----
3
4

query I rowsort
SELECT id FROM slt_scalar_expr WHERE a <> b AND label IS NOT NULL
----
1
3

query I nosort
SELECT SUM(a + b) FROM slt_scalar_expr
----
46

query I rowsort
SELECT id FROM slt_scalar_expr WHERE NOT (b < 4)
----
2
3
4

query T rowsort
SELECT label FROM slt_scalar_expr WHERE label LIKE 'g%'
----
gamma

query TT nosort
SELECT ifnull(NULL, 'fallback'), nullif('left', 'right')
----
fallback
left

query II nosort
SELECT
  CASE WHEN nullif('same', 'same') IS NULL THEN 1 ELSE 0 END,
  CASE WHEN ifnull('value', 'fallback') = 'value' THEN 1 ELSE 0 END
----
1
1

# CASE / COALESCE short-circuit: a non-taken branch or a skipped COALESCE
# argument must NOT be evaluated, so a fallible expression (division by zero)
# hidden in a non-taken position returns a value instead of raising. PostgreSQL
# behaves the same.
query I nosort
SELECT CASE WHEN false THEN 1 / 0 ELSE 99 END
----
99

query I nosort
SELECT CASE WHEN false THEN 1 / 0 WHEN true THEN 7 ELSE 1 / 0 END
----
7

query I nosort
SELECT CASE 1 WHEN 2 THEN 1 / 0 WHEN 1 THEN 5 ELSE 1 / 0 END
----
5

query I nosort
SELECT COALESCE(7, 1 / 0)
----
7

# The selected branch is still evaluated, so a fallible *taken* branch raises --
# short-circuiting must not swallow genuine errors (PostgreSQL errors too).
statement error
SELECT CASE WHEN true THEN 1 / 0 ELSE 99 END

statement ok
DROP TABLE slt_scalar_expr

# Data-driven COALESCE short-circuit: COALESCE stops at the first non-NULL, so a
# fallible later argument is skipped on rows where an earlier one is non-NULL.
statement ok
CREATE TABLE slt_short_circuit (a INT NOT NULL, c INT NOT NULL)

statement ok
INSERT INTO slt_short_circuit VALUES (10, 0), (20, 4)

# c = 0: the CASE yields 7, so `a / c` is never evaluated (no divide-by-zero).
query I nosort
SELECT COALESCE(CASE WHEN c = 0 THEN 7 ELSE NULL END, a / c) FROM slt_short_circuit WHERE c = 0
----
7

# c <> 0: the CASE is NULL, so COALESCE falls through to `a / c` (= 20 / 4).
query I nosort
SELECT COALESCE(CASE WHEN c = 0 THEN 7 ELSE NULL END, a / c) FROM slt_short_circuit WHERE c = 4
----
5

statement ok
DROP TABLE slt_short_circuit
