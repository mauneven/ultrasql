statement ok
CREATE TABLE wf9 (id INT NOT NULL, g INT NOT NULL, v INT NOT NULL)

statement ok
INSERT INTO wf9 VALUES (1,1,10),(2,1,20),(3,1,30),(4,2,40)

# Case 9: EXCLUDE TIES vs EXCLUDE GROUP over peers (g=1 has three peers).
query IIII nosort
SELECT id,
  sum(v) OVER (ORDER BY g RANGE BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING),
  sum(v) OVER (ORDER BY g RANGE BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING EXCLUDE TIES),
  sum(v) OVER (ORDER BY g RANGE BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING EXCLUDE GROUP)
FROM wf9 ORDER BY id
----
1
100
50
40
2
100
60
40
3
100
70
40
4
100
100
60

# Case 12: ranking functions ignore the frame; sum honors it.
statement ok
CREATE TABLE wf12 (id INT NOT NULL, v INT NOT NULL)

statement ok
INSERT INTO wf12 VALUES (1,10),(2,20),(3,20),(4,40)

query IIIII nosort
SELECT id,
  row_number() OVER (ORDER BY v),
  rank()       OVER (ORDER BY v),
  dense_rank() OVER (ORDER BY v),
  sum(v)       OVER (ORDER BY v ROWS BETWEEN 1 PRECEDING AND CURRENT ROW)
FROM wf12 ORDER BY id
----
1
1
1
1
10
2
2
2
2
30
3
3
2
2
40
4
4
4
3
60

# Case 13: no ORDER BY -> whole-partition default per group.
statement ok
CREATE TABLE wf13 (id INT NOT NULL, g TEXT NOT NULL, v INT NOT NULL)

statement ok
INSERT INTO wf13 VALUES (1,'a',10),(2,'a',20),(3,'b',30),(4,'b',40),(5,'b',50)

query III nosort
SELECT id,
  sum(v)   OVER (PARTITION BY g),
  count(*) OVER (PARTITION BY g)
FROM wf13 ORDER BY id
----
1
30
2
2
30
2
3
120
3
4
120
3
5
120
3

# Case 10: first/last/nth_value are frame-sensitive over a centered frame.
statement ok
CREATE TABLE wf10 (id INT NOT NULL, v INT NOT NULL)

statement ok
INSERT INTO wf10 VALUES (1,10),(2,20),(3,30),(4,40),(5,50)

query IIII nosort
SELECT id,
  first_value(v) OVER (ORDER BY id ROWS BETWEEN 1 PRECEDING AND 1 FOLLOWING),
  last_value(v)  OVER (ORDER BY id ROWS BETWEEN 1 PRECEDING AND 1 FOLLOWING),
  nth_value(v,2) OVER (ORDER BY id ROWS BETWEEN 1 PRECEDING AND 1 FOLLOWING)
FROM wf10 ORDER BY id
----
1
10
20
20
2
10
30
20
3
20
40
30
4
30
50
40
5
40
50
50

# Note: frame validation errors (case 16: RANGE offset needs exactly one
# ORDER BY column -> SQLSTATE 42P20; case 17: negative ROWS offset ->
# SQLSTATE 22013) are engine-divergent and therefore covered by the
# server round-trip tests and binder unit tests rather than this portable
# cross-engine differential shard.
