CREATE TABLE wf5 (id INT NOT NULL, g INT NOT NULL, v INT NOT NULL)

statement ok
INSERT INTO wf5 VALUES (1,1,10),(2,1,20),(3,2,30),(4,2,40),(5,3,50)

# Case 5: RANGE peers vs ROWS. Peers (g=1; g=2) share the RANGE result.
query III nosort
SELECT id,
  sum(v) OVER (ORDER BY g RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW),
  sum(v) OVER (ORDER BY g ROWS  BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW)
FROM wf5 ORDER BY id
----
1
30
10
2
30
30
3
100
60
4
100
100
5
150
150

