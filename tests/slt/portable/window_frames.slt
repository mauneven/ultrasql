query III nosort
SELECT id,
  sum(v)   OVER (ORDER BY g GROUPS BETWEEN 1 PRECEDING AND CURRENT ROW),
  count(*) OVER (ORDER BY g GROUPS BETWEEN 1 PRECEDING AND CURRENT ROW)
FROM wf7 ORDER BY id
