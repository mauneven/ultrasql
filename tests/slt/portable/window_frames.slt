# UltraSQL-authored portable SQLLogicTest shard.
# Scope: portable window frame coverage — ROWS / RANGE / GROUPS frame
# modes, all bound kinds, EXCLUDE options, aggregate window functions
# (SUM/AVG/COUNT/MIN/MAX/COUNT(*)), the default-frame contract, and
# frame-sensitive value functions. Results match PostgreSQL semantics.

statement ok
CREATE TABLE wf (id INT NOT NULL, v INT NOT NULL)

statement ok
INSERT INTO wf VALUES (1,10),(2,20),(3,30),(4,40)

# Case 1: default frame is a running total (RANGE UNBOUNDED..CURRENT ROW);
# empty OVER() is the whole-partition total.
query III nosort
SELECT id, sum(v) OVER (ORDER BY id), sum(v) OVER ()
FROM wf ORDER BY id
----
1
10
100
2
30
100
3
60
100
4
100
100

# Case 2: ROWS BETWEEN 1 PRECEDING AND CURRENT ROW (trailing pair).
query II nosort
SELECT id, sum(v) OVER (ORDER BY id ROWS BETWEEN 1 PRECEDING AND CURRENT ROW)
FROM wf ORDER BY id
----
1
10
2
30
3
50
4
70

# Case 3: ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING (suffix).
query II nosort
SELECT id, sum(v) OVER (ORDER BY id ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING)
FROM wf ORDER BY id
----
1
100
2
90
3
70
4
40

# Case 4: ROWS BETWEEN 1 PRECEDING AND 1 FOLLOWING (centered).
query II nosort
SELECT id, sum(v) OVER (ORDER BY id ROWS BETWEEN 1 PRECEDING AND 1 FOLLOWING)
FROM wf ORDER BY id
----
1
30
2
60
3
90
4
70

# Case 8: EXCLUDE CURRENT ROW over a whole-partition frame.
query II nosort
SELECT id, sum(v) OVER (ORDER BY id ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING EXCLUDE CURRENT ROW)
FROM wf ORDER BY id
----
1
90
2
80
3
70
4
60

statement ok
CREATE TABLE wf5 (id INT NOT NULL, g INT NOT NULL, v INT NOT NULL)

statement ok
INSERT INTO wf5 VALUES (1,1,10),(2,1,20),(3,2,30),(4,2,40),(5,3,50)

# Case 5: RANGE peers vs ROWS. Peers (g=1; g=2) share the RANGE result.
query III nosort
SELECT id,
  sum(v) OVER (ORDER BY g RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW),
  sum(v) OVER (ORDER BY g ROWS  BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW)
FROM wf5 ORDER BY id
----
1
30
10
2
30
30
3
100
60
4
100
100
5
150
150

statement ok
CREATE TABLE wf6 (id INT NOT NULL, v INT NOT NULL)

statement ok
INSERT INTO wf6 VALUES (1,10),(2,15),(3,20),(4,40),(5,45)

# Case 6: RANGE numeric value offset [v-10, v+10].
query III nosort
SELECT id,
  sum(v)   OVER (ORDER BY v RANGE BETWEEN 10 PRECEDING AND 10 FOLLOWING),
  count(*) OVER (ORDER BY v RANGE BETWEEN 10 PRECEDING AND 10 FOLLOWING)
FROM wf6 ORDER BY id
----
1
45
3
2
45
3
3
45
3
4
85
2
5
85
2

