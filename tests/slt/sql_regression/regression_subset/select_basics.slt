statement ok
CREATE TABLE slt_pg_select (id INT NOT NULL, score INT, label TEXT)

statement ok
INSERT INTO slt_pg_select VALUES (1, 42, 'forty-two'), (2, 3, 'three'), (3, 10, 'ten'), (4, 7, 'seven'), (5, NULL, 'missing')

query IT nosort
SELECT id, label FROM slt_pg_select WHERE id < 3 ORDER BY id
----
1
forty-two
2
three

query II nosort
SELECT id, score FROM slt_pg_select WHERE score IS NOT NULL ORDER BY score DESC, id
----
1
42
3
10
4
7
2
3

query I rowsort
SELECT id FROM slt_pg_select WHERE (id, score) IN ((1, 42), (3, 10), (5, 0))
----
1
3

query II rowsort
SELECT id, score FROM slt_pg_select WHERE score BETWEEN 7 AND 42
----
1
42
3
10
4
7

query I nosort
SELECT COUNT(*) FROM slt_pg_select WHERE score IS NULL
----
1

statement ok
DROP TABLE slt_pg_select
