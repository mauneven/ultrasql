# PostgreSQL regression-derived expression/predicate baseline shard.
# Source: PostgreSQL src/test/regress/sql/select.sql and expressions exercised
# across the public regression suite at commit ddd12d1a5c4d980c5f31dc7d096012547b724e55.
# License/provenance live beside this file in IMPORT_MANIFEST.txt and
# LICENSE.upstream.

statement ok
CREATE TABLE slt_pg_expr_predicate (
  id INT NOT NULL,
  a INT,
  b INT,
  label TEXT
)

statement ok
INSERT INTO slt_pg_expr_predicate VALUES
  (1, 10, 10, 'Alpha'),
  (2, 10, NULL, 'beta'),
  (3, NULL, NULL, 'Gamma'),
  (4, 4, 9, 'delta')

query I rowsort
SELECT id FROM slt_pg_expr_predicate WHERE a IS DISTINCT FROM b
----
2
4

query I rowsort
SELECT id FROM slt_pg_expr_predicate WHERE a IS NOT DISTINCT FROM b
----
1
3

query I nosort
SELECT id FROM slt_pg_expr_predicate WHERE label ILIKE 'a%'
----
1

query B nosort
SELECT 'a_b' LIKE 'a\_b'
----
true

query B nosort
SELECT 'sale%2026' LIKE 'sale\%2026'
----
true

query II rowsort
SELECT id, NULLIF(a, b) FROM slt_pg_expr_predicate WHERE id IN (1, 2, 4)
----
1
NULL
2
10
4
4

query IIII rowsort
SELECT id, GREATEST(a, b, 5), LEAST(a, b, 5), CASE WHEN a BETWEEN SYMMETRIC 12 AND 5 THEN 1 ELSE 0 END
FROM slt_pg_expr_predicate
WHERE id IN (1, 2, 4)
----
1
10
5
1
2
10
5
1
4
9
4
0

statement ok
DROP TABLE slt_pg_expr_predicate

statement ok
CREATE TABLE slt_pg_bool_predicate (
  id INT NOT NULL,
  flag BOOL
)

statement ok
INSERT INTO slt_pg_bool_predicate VALUES
  (1, TRUE),
  (2, FALSE),
  (3, NULL)

query I nosort
SELECT id FROM slt_pg_bool_predicate WHERE flag IS TRUE
----
1

query I rowsort
SELECT id FROM slt_pg_bool_predicate WHERE flag IS NOT TRUE
----
2
3

query I nosort
SELECT id FROM slt_pg_bool_predicate WHERE flag IS FALSE
----
2

query I rowsort
SELECT id FROM slt_pg_bool_predicate WHERE flag IS NOT FALSE
----
1
3

query I nosort
SELECT id FROM slt_pg_bool_predicate WHERE flag IS UNKNOWN
----
3

query I rowsort
SELECT id FROM slt_pg_bool_predicate WHERE flag IS NOT UNKNOWN
----
1
2

statement ok
DROP TABLE slt_pg_bool_predicate
