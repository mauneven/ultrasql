# PostgreSQL regression-derived type-specific baseline shard.
# Source: PostgreSQL src/test/regress/sql/numeric.sql, text.sql, date.sql,
# time.sql, timetz.sql, timestamp.sql, json.sql, jsonb.sql, and arrays.sql at
# commit ddd12d1a5c4d980c5f31dc7d096012547b724e55.
# License/provenance live beside this file in IMPORT_MANIFEST.txt and
# LICENSE.upstream.

statement ok
CREATE TABLE slt_pg_type_specific (
  id INT NOT NULL,
  amount NUMERIC(8,2),
  note TEXT,
  d DATE,
  t TIME,
  z TIMETZ,
  ts TIMESTAMP,
  tstz TIMESTAMPTZ,
  doc JSONB,
  nums INT[]
)

statement ok
INSERT INTO slt_pg_type_specific VALUES
  (1, 12.30, 'alpha', DATE '2024-05-22', TIME '13:14:15', TIMETZ '13:14:15-05', TIMESTAMP '2024-05-22 13:14:15', TIMESTAMPTZ '2024-05-22 13:14:15+00', '{"kind":"guide","items":[1,2]}'::jsonb, [1, 2, 3]),
  (2, -7.25, 'beta', DATE '2024-05-23', TIME '09:00:00', TIMETZ '09:00:00+02', TIMESTAMP '2024-05-23 09:00:00', TIMESTAMPTZ '2024-05-23 09:00:00+00', '{"kind":"paper","items":[3]}'::jsonb, [4, 5]),
  (3, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL)

query I nosort
SELECT id FROM slt_pg_type_specific WHERE amount + 0.70 = 13.00
----
1

query I nosort
SELECT id FROM slt_pg_type_specific WHERE amount < 0
----
2

query I nosort
SELECT COUNT(*) FROM slt_pg_type_specific WHERE amount IS NULL
----
1

query II rowsort
SELECT id, length(note) FROM slt_pg_type_specific WHERE note IS NOT NULL
----
1
5
2
4

query I nosort
SELECT id FROM slt_pg_type_specific WHERE note LIKE 'a%'
----
1

query I nosort
SELECT id FROM slt_pg_type_specific WHERE note <> 'alpha'
----
2

query I nosort
SELECT id FROM slt_pg_type_specific WHERE d >= DATE '2024-05-23'
----
2

query I nosort
SELECT id FROM slt_pg_type_specific WHERE t < TIME '10:00:00'
----
2

query I nosort
SELECT id FROM slt_pg_type_specific WHERE z = TIMETZ '13:14:15-05'
----
1

query I nosort
SELECT id FROM slt_pg_type_specific WHERE ts >= TIMESTAMP '2024-05-23 00:00:00'
----
2

query I nosort
SELECT id FROM slt_pg_type_specific WHERE tstz = TIMESTAMPTZ '2024-05-22 13:14:15+00'
----
1

query IT rowsort
SELECT id, doc ->> 'kind' FROM slt_pg_type_specific WHERE doc IS NOT NULL
----
1
guide
2
paper

query I nosort
SELECT id FROM slt_pg_type_specific WHERE doc @> '{"kind":"guide"}'::jsonb
----
1

query B nosort
SELECT jsonb_path_exists('{"items":[{"score":12},{"score":25}]}'::jsonb, '$.items[*] ? (@.score >= 20)')
----
true

query II rowsort
SELECT id, array_length(nums, 1) FROM slt_pg_type_specific WHERE nums IS NOT NULL
----
1
3
2
2

query I nosort
SELECT id FROM slt_pg_type_specific WHERE array_length(nums, 1) = 3
----
1

# ultrasql:skip full PostgreSQL type-specific regression breadth needs exhaustive numeric overflow, text collation, timezone abbreviation, SQL/JSON, and array slice parity
query I nosort
SELECT COUNT(*) FROM pg_type WHERE typname IN ('numeric', 'text', 'date', 'jsonb', '_int4')
----
5

statement ok
DROP TABLE slt_pg_type_specific
