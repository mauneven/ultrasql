#!/usr/bin/env bash
# Pre-push: validate the TEST SUITE only — nothing more.
#
# The full gate (fmt, clippy, cargo-doc strict, cargo-deny, regression bench,
# parser fuzz, and the per-crate llvm-cov coverage floor) still runs on the
# remote for every push/merge via .github/workflows/ci.yml + coverage.yml.
# Keeping the local pre-push to just the tests trades a little remote-only risk
# for a fast local push. The previous all-gates hook is in git history if you
# want to restore it.
#
# Runs the ENTIRE suite (lib + integration) WITHOUT coverage instrumentation,
# which is what made the old gate slow. A single failing test refuses the push.
#
# Escape hatches:
#   --no-verify                 bypass entirely
#   docs/bench-only diff         auto-skipped (nothing to test)

set -e -o pipefail

cd "$(git rev-parse --show-toplevel)"

if ! command -v cargo >/dev/null 2>&1; then
    # Shell sourced from a non-interactive context (e.g. gh CLI) may not have
    # $CARGO_HOME on PATH. Source the standard rustup env.
    if [ -f "$HOME/.cargo/env" ]; then
        # shellcheck disable=SC1091
        . "$HOME/.cargo/env"
    fi
fi

# Maximise parallelism; keep the incremental cache from bloating local disk.
export CARGO_BUILD_JOBS
CARGO_BUILD_JOBS="$(sysctl -n hw.ncpu 2>/dev/null || nproc 2>/dev/null || echo 4)"
export CARGO_INCREMENTAL=0

# ── Auto-skip: nothing to test when only docs/bench files changed ────────────
_changed_files() {
    if git rev-parse --verify HEAD~1 >/dev/null 2>&1; then
        git diff --name-only HEAD~1 HEAD 2>/dev/null || true
    fi
}

_is_docs_or_bench_only() {
    local changed
    changed=$(_changed_files)
    [ -z "$changed" ] && return 1   # no detectable diff → run the tests
    while IFS= read -r f; do
        case "$f" in
            *.md | docs/*) ;;                       # docs
            */benches/* | benches/*) ;;             # bench source
            benchmarks/results/latest/*) ;;         # bench results
            *) return 1 ;;                          # a real source file
        esac
    done <<< "$changed"
    return 0
}

if _is_docs_or_bench_only; then
    printf "\n\033[1;33m== tests skipped (docs/bench-only diff) ==\033[0m\n"
    exit 0
fi

# ── Tests (full suite: lib + integration, no coverage instrumentation) ───────
printf "\n\033[1m== cargo test --workspace --all-features ==\033[0m\n"
cargo test --workspace --all-features

printf "\n\033[1;32m== tests passed; push allowed ==\033[0m\n"
