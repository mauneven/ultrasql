#!/usr/bin/env bash
# Run every gate the CI runs, before letting the push leave the box.
# Refuses the push on any failure. Bypassable with --no-verify if you
# really know what you're doing.
#
# Mirrors .github/workflows/ci.yml. If a new CI gate lands, add it here.
#
# Regression gate escape hatch:
#   ULTRASQL_SKIP_BENCH=1 git push
#
# This skips the regression gate for documentation-only commits. The gate
# is also automatically skipped when only .md / docs/** files changed.

set -e -o pipefail

cd "$(git rev-parse --show-toplevel)"

if ! command -v cargo >/dev/null 2>&1; then
    # Shell sourced from a non-interactive context (e.g. gh CLI) may
    # not have $CARGO_HOME on PATH. Source the standard rustup env.
    if [ -f "$HOME/.cargo/env" ]; then
        # shellcheck disable=SC1091
        . "$HOME/.cargo/env"
    fi
fi

step() {
    printf "\n\033[1m== %s ==\033[0m\n" "$1"
}

step "cargo fmt --all -- --check"
cargo fmt --all -- --check

step "cargo clippy --workspace --all-targets --all-features -- -D warnings"
cargo clippy --workspace --all-targets --all-features -- -D warnings

step "cargo doc --workspace --all-features --no-deps  (strict)"
RUSTDOCFLAGS="-D warnings -D rustdoc::broken-intra-doc-links" \
    cargo doc --workspace --all-features --no-deps

if command -v cargo-deny >/dev/null 2>&1; then
    step "cargo deny check advisories bans licenses sources"
    cargo deny check advisories bans licenses sources
else
    printf "\n\033[1;33m== cargo-deny not installed locally — skipped. brew install cargo-deny ==\033[0m\n"
fi

step "cargo test --workspace --all-features"
cargo test --workspace --all-features

# ---------------------------------------------------------------------------
# Regression gate
# ---------------------------------------------------------------------------
#
# Detects whether the push includes any non-documentation file changes. If
# only .md files or docs/** changed the gate is skipped to avoid making
# documentation PRs expensive.
#
# Full skip: ULTRASQL_SKIP_BENCH=1 git push
#   Allowed ONLY for documentation-only commits. Using this on a source
#   change is a policy violation; the CI bench job will catch it anyway.

step "regression gate (benchmark regression + competitor floor check)"

_run_regression_gate() {
    cargo run --release --package ultrasql-bench --bin regression-gate -- \
        --stage current \
        --iterations 5 \
        --warmup 1
}

_changed_files() {
    # List files changed between the remote tip and the local HEAD.
    # On a brand-new branch or before the first push, compare against the
    # merge-base with main; fall back to HEAD~1 when that fails.
    local remote_ref
    # Read the remote tip SHA from the hook's stdin (format: <local ref> <local sha> <remote ref> <remote sha>)
    # We use git diff-tree against the recorded remote sha when available.
    if git rev-parse --verify HEAD~1 >/dev/null 2>&1; then
        git diff --name-only HEAD~1 HEAD 2>/dev/null || true
    fi
}

_is_docs_only() {
    local changed
    changed=$(_changed_files)
    if [ -z "$changed" ]; then
        # No detectable diff — be conservative and run the gate.
        return 1
    fi
    # Return 0 (true) only when EVERY changed file is docs-only.
    while IFS= read -r f; do
        case "$f" in
            *.md | docs/* | docs\\*) ;;  # docs-only file: continue
            *) return 1 ;;               # source file found: not docs-only
        esac
    done <<< "$changed"
    return 0
}

if [ -n "${ULTRASQL_SKIP_BENCH:-}" ]; then
    printf "\n\033[1;33m== regression gate skipped (ULTRASQL_SKIP_BENCH set) ==\033[0m\n"
    printf "   NOTE: allowed only for documentation-only commits.\n"
    printf "   The CI bench job will enforce the gate on the remote.\n"
elif _is_docs_only; then
    printf "\n\033[1;33m== regression gate skipped (docs-only diff detected) ==\033[0m\n"
else
    _run_regression_gate
fi

printf "\n\033[1;32m== all gates green; push allowed ==\033[0m\n"
