#!/usr/bin/env bash
# Auto-render README.md benchmark tables from current baseline data +
# static defaults, then re-stage the file when it changed.
#
# This hook runs before every commit. It keeps the README benchmark
# tables in sync with benchmarks/baselines/ without requiring a manual
# step. If the README was already up to date the hook exits silently.
#
# Wire this hook once per clone:
#   git config core.hooksPath .githooks

set -e -o pipefail

cd "$(git rev-parse --show-toplevel)"

if ! command -v cargo >/dev/null 2>&1; then
    if [ -f "$HOME/.cargo/env" ]; then
        # shellcheck disable=SC1091
        . "$HOME/.cargo/env"
    fi
fi

# Auto-render README from current baseline data + static defaults.
cargo run --release --package ultrasql-bench --bin readme-render -- \
    --readme README.md \
    --baselines benchmarks/baselines

# Re-stage only if README changed.
if ! git diff --quiet README.md; then
    git add README.md
    printf "\n\033[1;33m== README.md auto-regenerated and re-staged ==\033[0m\n"
fi
