#!/usr/bin/env bash
# Block generated attribution trailers.
set -e

msg_file="$1"

# Match trailers we do NOT allow anywhere in the commit message.
forbidden_patterns=(
    'Co-[Aa]uthored-[Bb]y:'
    'Generated with'
    'Generated by'
)

for pattern in "${forbidden_patterns[@]}"; do
    if grep -Eq "$pattern" "$msg_file"; then
        echo "commit-msg hook: refusing commit — forbidden trailer matched /$pattern/."
        echo "Strip it from the commit message and try again."
        echo ""
        echo "Offending line(s):"
        grep -En "$pattern" "$msg_file"
        exit 1
    fi
done

exit 0
