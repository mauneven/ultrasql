# UltraSQL server environment.
#
# Every ultrasqld flag can be set here as an ULTRASQL_* variable; run
# `ultrasqld --help` for the full list. The server REFUSES to expose an
# unauthenticated listener on a non-loopback address, so to accept remote
# clients you must (1) set ULTRASQL_LISTEN to a public address AND (2) configure
# authentication (and, strongly recommended, TLS).

# PostgreSQL wire listener bind. Default is loopback-only, so a fresh install is
# never publicly exposed. To accept remote clients set e.g. 0.0.0.0:5432 and
# configure authentication below.
ULTRASQL_LISTEN=127.0.0.1:5432

# Data directory (WAL-backed durable storage).
ULTRASQL_DATA_DIR=/var/lib/ultrasql

# --- Authentication (REQUIRED for any non-loopback ULTRASQL_LISTEN) ---
# SCRAM-SHA-256 password auth for a single startup role:
#ULTRASQL_AUTH_USER=ultrasql
#ULTRASQL_AUTH_PASSWORD_FILE=/etc/ultrasql/password
#ULTRASQL_AUTH_METHOD=scram
# ...or pg_hba.conf-style per-role rules (mutually exclusive with the above):
#ULTRASQL_HBA_FILE=/etc/ultrasql/pg_hba.conf

# --- TLS (recommended whenever listening off-host) ---
#ULTRASQL_TLS_CERT=/etc/ultrasql/server.crt
#ULTRASQL_TLS_KEY=/etc/ultrasql/server.key

# --- Operations endpoint (/health, /ready, /metrics) ---
#ULTRASQL_OPS_LISTEN=127.0.0.1:9100
#ULTRASQL_OPS_TOKEN=change-me-for-backup-routes
