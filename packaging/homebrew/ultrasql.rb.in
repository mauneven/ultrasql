class Ultrasql < Formula
  desc "Fast SQL database in Rust"
  homepage "https://ultrasql.org"
  url "https://github.com/mauneven/ultrasql/releases/download/v@VERSION@/ultrasql-v@VERSION@-source.tar.gz"
  sha256 "@SHA256_SOURCE@"
  license "Apache-2.0 OR MIT"

  depends_on "rust" => :build

  def install
    system "cargo", "install", "--locked", "--path", "crates/ultrasql-server",
           "--root", prefix, "--profile", "release-ship"
    system "cargo", "install", "--locked", "--path", "crates/ultrasql-cli",
           "--root", prefix, "--profile", "release-ship"
    rm_f prefix/".crates.toml"
    rm_f prefix/".crates2.json"
  end

  test do
    assert_match version.to_s, shell_output("#{bin}/ultrasqld --version")
    assert_match "UltraSQL command-line client", shell_output("#{bin}/ultrasql --help")
    assert_match "UltraSQL", shell_output("#{bin}/ultrasql-local --help")
  end
end
