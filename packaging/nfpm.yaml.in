name: ultrasql
arch: "@ARCH@"
platform: linux
version: "@VERSION@"
release: "1"
section: database
priority: optional
maintainer: ultrasql <contact@ultrasql.org>
homepage: https://ultrasql.org
license: Apache-2.0 OR MIT
description: Fast SQL database in Rust.
vendor: UltraSQL
contents:
  - src: "@ROOT@/usr/bin/ultrasqld"
    dst: /usr/bin/ultrasqld
    file_info:
      mode: 0755
  - src: "@ROOT@/usr/bin/ultrasql"
    dst: /usr/bin/ultrasql
    file_info:
      mode: 0755
  - src: "@ROOT@/usr/bin/ultrasql-local"
    dst: /usr/bin/ultrasql-local
    file_info:
      mode: 0755
  - src: packaging/linux/ultrasqld.service
    dst: /lib/systemd/system/ultrasqld.service
    file_info:
      mode: 0644
  - src: packaging/linux/ultrasqld.env
    dst: /etc/ultrasql/ultrasqld.env
    type: config|noreplace
    file_info:
      mode: 0644
  - src: README.md
    dst: /usr/share/doc/ultrasql/README.md
    file_info:
      mode: 0644
  - src: docs/install.md
    dst: /usr/share/doc/ultrasql/install.md
    file_info:
      mode: 0644
  - src: LICENSE-APACHE
    dst: /usr/share/licenses/ultrasql/LICENSE-APACHE
    file_info:
      mode: 0644
  - src: LICENSE-MIT
    dst: /usr/share/licenses/ultrasql/LICENSE-MIT
    file_info:
      mode: 0644
scripts:
  preinstall: packaging/linux/preinstall.sh
  postinstall: packaging/linux/postinstall.sh
overrides:
  deb:
    depends:
      - ca-certificates
  rpm:
    depends:
      - ca-certificates
