{
  "name": "ultrasql",
  "version": "0.0.6",
  "description": "Embedded UltraSQL database API plus server and CLI binaries.",
  "license": "Apache-2.0 OR MIT",
  "homepage": "https://github.com/mauneven/ultrasql#readme",
  "keywords": [
    "database",
    "sql",
    "embedded",
    "node-api",
    "bun",
    "oltp",
    "olap",
    "vector",
    "rust",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mauneven/ultrasql.git",
    "directory": "packages/npm"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "bugs": {
    "url": "https://github.com/mauneven/ultrasql/issues"
  },
  "bin": {
    "ultrasql": "bin/ultrasql.js",
    "ultrasqld": "bin/ultrasqld.js",
    "ultrasql-local": "bin/ultrasql-local.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js"
  },
  "files": [
    "bin",
    "index.d.ts",
    "index.js",
    "LICENSE-APACHE",
    "LICENSE-MIT",
    "prebuilds",
    "scripts",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ]
}
